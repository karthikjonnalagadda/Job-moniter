# =============================================================================
# .gitignore — AI Job Intelligence Agent
# Keeps the repository to production assets only: source, config templates,
# docs, tests, CI/CD. All runtime output, caches, secrets, and personal data
# are excluded.
# =============================================================================

# ---- Secrets & credentials --------------------------------------------------
.env
.env.*
!.env.example
secrets.json
credentials.json
*.pem
*.key

# ---- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# ---- Tooling caches ---------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ---- Generated reports & runtime output -------------------------------------
reports/generated/*
reports/history/*
reports/output/*
reports/temp/*
exports/*
!exports/.gitkeep
analytics/*
logs/*
!logs/.gitkeep
archives/*
scheduler/*
benchmark/*
*.log

# ---- Generated data exports (regenerated by the build CLIs) -----------------
uat*_result.json
ats_detect_result.json

# ---- MongoDB dumps / backups ------------------------------------------------
dumps/
backups/

# ---- Vector / embedding / model caches --------------------------------------
embeddings/*
cache/*
.cache/
vector_cache/*
atlas_cache/*
faiss/*
chroma/*
models/

# ---- Personal data (never commit) -------------------------------------------
data/resume/*
!data/resume/.gitkeep

# ---- IDE --------------------------------------------------------------------
.idea/
.vscode/
*.iml

# ---- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db
