# =============================================================================
# AI Job Intelligence Agent — Environment Configuration TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All variables are prefixed `JOBAGENT_`; nested settings use `__` (double
# underscore), e.g. JOBAGENT_RANKING__WEIGHT_SIMILARITY=0.34
# In production (Render / GitHub Actions), set secrets as encrypted env vars
# rather than shipping a .env file.
# =============================================================================

# ---- Application ------------------------------------------------------------
JOBAGENT_APP_NAME="AI Job Intelligence Agent"
JOBAGENT_ENV=development                  # development | staging | production
JOBAGENT_DEBUG=true
JOBAGENT_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
JOBAGENT_LOG_JSON=false                    # true => structured JSON logs (prod)
JOBAGENT_LOG_DIR=logs
JOBAGENT_API_HOST=0.0.0.0
JOBAGENT_API_PORT=8000

# ---- MongoDB Atlas ----------------------------------------------------------
# Use an Atlas cluster with Vector Search enabled (M10+ recommended) for
# production semantic ranking. Local dev may point at any MongoDB with the
# numpy scorer (JOBAGENT_VECTOR__BACKEND=numpy).
JOBAGENT_MONGO__URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Cluster0"
JOBAGENT_MONGO__DB_NAME=job_intelligence
JOBAGENT_MONGO__MAX_POOL_SIZE=20
JOBAGENT_MONGO__SERVER_SELECTION_TIMEOUT_MS=5000

# ---- Vector Search ----------------------------------------------------------
JOBAGENT_VECTOR__BACKEND=atlas             # atlas | numpy  (numpy = local/tests)
JOBAGENT_VECTOR__INDEX_NAME=jobs_vector_index
JOBAGENT_VECTOR__DIMENSIONS=384
JOBAGENT_VECTOR__SIMILARITY=cosine         # cosine | dotProduct | euclidean
JOBAGENT_VECTOR__NUM_CANDIDATES=200
JOBAGENT_VECTOR__LIMIT=100

# ---- Embeddings -------------------------------------------------------------
JOBAGENT_EMBEDDING__MODEL_NAME=BAAI/bge-small-en-v1.5
JOBAGENT_EMBEDDING__DEVICE=cpu             # cpu | cuda
JOBAGENT_EMBEDDING__NORMALIZE=true
JOBAGENT_EMBEDDING__BATCH_SIZE=32
# bge models want an instruction prefix on the QUERY (resume) side only:
JOBAGENT_EMBEDDING__QUERY_INSTRUCTION="Represent this resume for retrieving relevant job descriptions: "

# ---- Ranking formula (must sum to 1.0; validated at startup) ----------------
JOBAGENT_RANKING__WEIGHT_SIMILARITY=0.34
JOBAGENT_RANKING__WEIGHT_SKILL=0.24
JOBAGENT_RANKING__WEIGHT_EXPERIENCE=0.14
JOBAGENT_RANKING__WEIGHT_LOCATION=0.10
JOBAGENT_RANKING__WEIGHT_COMPANY_PRIORITY=0.10
JOBAGENT_RANKING__WEIGHT_FRESHNESS=0.03
JOBAGENT_RANKING__WEIGHT_QUALITY=0.05
JOBAGENT_RANKING__MIN_SCORE=70             # 0-100; jobs below this are dropped

# ---- Freshness / experience gates -------------------------------------------
JOBAGENT_FILTERS__MAX_AGE_HOURS=24
JOBAGENT_FILTERS__MAX_EXPERIENCE_YEARS=2
JOBAGENT_FILTERS__ALLOW_IF_ENTRY_LEVEL=true

# ---- SMTP email -------------------------------------------------------------
# For Gmail, generate an App Password (not your account password) and set it
# here / in your deployment secrets. Leave blank to disable email.
JOBAGENT_SMTP__HOST=smtp.gmail.com
JOBAGENT_SMTP__PORT=587
JOBAGENT_SMTP__USERNAME=your-address@example.com
JOBAGENT_SMTP__PASSWORD=<app-password>
JOBAGENT_SMTP__USE_TLS=true
JOBAGENT_SMTP__FROM_ADDRESS="AI Job Agent <your-address@example.com>"
JOBAGENT_SMTP__TO_ADDRESS=recipient@example.com

# ---- Collector HTTP defaults ------------------------------------------------
JOBAGENT_HTTP__USER_AGENT="AIJobIntelligenceAgent/2026 (+https://example.com/bot)"
JOBAGENT_HTTP__TIMEOUT_SECONDS=20
JOBAGENT_HTTP__MAX_RETRIES=3
JOBAGENT_HTTP__DEFAULT_RATE_LIMIT_RPS=2

# ---- Paths ------------------------------------------------------------------
JOBAGENT_PATHS__ATS_SOURCES_FILE=data/ats_sources.yaml
JOBAGENT_PATHS__COMPANIES_SEED_FILE=data/companies/companies.sample.csv
JOBAGENT_PATHS__RESUME_FILE=data/resume/resume.txt
JOBAGENT_PATHS__EXPORT_DIR=exports
